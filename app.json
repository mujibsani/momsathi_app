{
  "expo": {
    "name": "momshathi_app",
    "slug": "momshathi_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "NOTIFICATIONS"
      ],
      "package": "com.protiksani.momshathi_app"
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "70ae4afa-7722-4df4-a070-53ee3c2efe54"
      }
    }
  }
}
